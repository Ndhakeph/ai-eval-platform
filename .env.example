# FastRouter API key (OpenAI-compatible, get one at https://fastrouter.ai)
FASTROUTER_API_KEY=your_fastrouter_api_key_here

# LLM model to use (default: openai/gpt-4o-mini)
LLM_MODEL=openai/gpt-4o-mini

# Supabase project credentials (get from https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
